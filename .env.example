# Firebase Configuration
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://your_project-default-rtdb.firebaseio.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Default Allowed Users (comma-separated emails)
# These users will always have edit access
VITE_DEFAULT_ALLOWED_USERS=admin@example.com,user@example.com

# Sentry Error Tracking (optional — leave blank to disable)
# Get your DSN from https://sentry.io → Project Settings → Client Keys
VITE_SENTRY_DSN=
