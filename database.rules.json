{
  "rules": {
    // Programs - public read (map is public-viewable), authenticated write
    "programs": {
      ".read": true,
      ".write": "auth != null"
    },

    // Events - public read (public calendar), authenticated write
    "events": {
      ".read": true,
      ".write": "auth != null"
    },

    // Target programs pipeline - sensitive, auth required to read or write
    "targetPrograms": {
      ".read": "auth != null",
      ".write": "auth != null"
    },

    // Target notes - sensitive, auth required
    "targetNotes": {
      ".read": "auth != null",
      ".write": "auth != null"
    },

    // Target ranking metrics - sensitive, auth required
    "targetRankingMetrics": {
      ".read": "auth != null",
      ".write": "auth != null"
    },

    // Notes - auth required
    "notes": {
      ".read": "auth != null",
      ".write": "auth != null"
    },

    // Schedule entries - auth required
    "schedule": {
      ".read": "auth != null",
      ".write": "auth != null"
    },

    // History logs - auth required
    "history": {
      ".read": "auth != null",
      ".write": "auth != null"
    },

    // Social metrics - auth required
    "socialMetrics": {
      ".read": "auth != null",
      ".write": "auth != null"
    },

    // Ranking metrics - auth required
    "rankingMetrics": {
      ".read": "auth != null",
      ".write": "auth != null"
    },

    // Mentions - auth required
    "mentions": {
      ".read": "auth != null",
      ".write": "auth != null"
    },

    // Contract details (sensitive) - auth required
    "contractDetails": {
      ".read": "auth != null",
      ".write": "auth != null"
    },

    // Contract history - auth required
    "contractHistory": {
      ".read": "auth != null",
      ".write": "auth != null"
    },

    // Competitor events - auth required
    "competitorEvents": {
      ".read": "auth != null",
      ".write": "auth != null"
    },

    // Allowed users list - auth required
    "allowedUsers": {
      ".read": "auth != null",
      ".write": "auth != null"
    }
  }
}
